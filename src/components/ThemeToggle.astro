<button class="icon-btn" id="theme-toggle" aria-label="Cambiar tema" title="Cambiar tema">
  <span class="theme-icon-wrapper">
    <span id="theme-icon-moon" class="theme-icon active">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><use href="#icon-moon"/></svg>
    </span>
    <span id="theme-icon-sun" class="theme-icon">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><use href="#icon-sun"/></svg>
    </span>
  </span>
</button>

